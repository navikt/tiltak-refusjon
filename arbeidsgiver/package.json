{
    "name": "tiltak-refusjon-arbeidsgiver",
    "version": "0.1.0",
    "private": true,
    "engines": {
        "node": ">=24",
        "npm": "please-use-pnpm",
        "yarn": "please-use-pnpm",
        "pnpm": ">=10"
    },
    "scripts": {
        "dev": "vite",
        "start": "pnpm run dev",
        "build": "tsc && vite build",
        "test-and-build": "pnpm run test && pnpm run build",
        "preview": "vite preview",
        "pretty-svg": "pretty-quick --staged --pattern \"**/*.*(js|json|jsx|ts|tsx|css|scss|less)\" && sh ./svgo.sh",
        "test": "vitest --environment=jsdom --run",
        "storybook": "storybook dev -p 6006",
        "release": "NODE_OPTIONS=--openssl-legacy-provider cross-env GIT_COMMIT_HASH=$(git log -n 1 --pretty=format:'%h') node ./sentry.js",
        "build-storybook": "storybook build"
    },
    "dependencies": {
        "@navikt/aksel-icons": "^7.40.0",
        "@navikt/bedriftsmeny": "^7.0.6",
        "@navikt/ds-css": "^7.40.0",
        "@navikt/ds-icons": "3.4.3",
        "@navikt/ds-react": "^7.40.0",
        "@navikt/fnrvalidator": "^2.2.1",
        "@sentry/browser": "^9.47.1",
        "@sentry/react": "^9.47.1",
        "axios": "^1.16.0",
        "classnames": "2.5.1",
        "cookie-parser": "^1.4.7",
        "http-proxy-middleware": "^3.0.5",
        "lodash.groupby": "^4.6.0",
        "lodash.sortby": "^4.7.0",
        "lodash.sumby": "^4.6.0",
        "moment": "^2.30.1",
        "norsk-validator": "^1.2.0",
        "react": "^19.2.5",
        "react-collapse": "^5.1.1",
        "react-dom": "^19.2.5",
        "react-modal": "^3.16.3",
        "react-responsive": "^10.0.1",
        "react-router": "^7.14.2",
        "swr": "^2.4.1"
    },
    "devDependencies": {
        "@sentry/cli": "^2.58.5",
        "@storybook/addon-docs": "^9.1.20",
        "@storybook/addon-links": "^9.1.20",
        "@storybook/addon-onboarding": "^9.1.20",
        "@storybook/react-vite": "^9.1.20",
        "@testing-library/react": "^16.3.2",
        "@types/history": "^4.7.11",
        "@types/lodash.groupby": "^4.6.9",
        "@types/lodash.sortby": "^4.7.9",
        "@types/lodash.sumby": "^4.6.9",
        "@types/node": "^22.19.17",
        "@types/react": "^19.2.14",
        "@types/react-collapse": "^5.0.4",
        "@types/react-dom": "^19.2.3",
        "@types/react-modal": "^3.16.3",
        "@types/react-responsive": "^8.0.8",
        "@vitejs/plugin-react": "^4.7.0",
        "cross-env": "^7.0.3",
        "jsdom": "^26.1.0",
        "less": "^4.6.4",
        "pretty-quick": "^4.2.2",
        "storybook": "^9.1.20",
        "svgo": "^3.3.3",
        "typescript": "^5.9.3",
        "vite": "^6.4.2",
        "vite-plugin-svgr": "^4.5.0",
        "vitest": "^3.2.4"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.60.2"
    }
}
